<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:fontFamily">@font/sf_r</item>
    </style>

    <style name="Theme_Dialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowMinWidthMajor">96%</item>
        <item name="android:windowMinWidthMinor">96%</item>
    </style>

    <style name="MarkerTitle" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:fontFamily">@font/sf_r</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="PolyLineLabelTextStyle" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:fontFamily">@font/sf_r</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="WizardPageTitle">
        <item name="android:id">@android:id/title</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">23sp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:fontFamily">sans-serif-thin</item>
    </style>

    <style name="WizardPageTitleLarge" parent="WizardPageTitle">
        <item name="android:textSize">36sp</item>
    </style>

    <style name="WizardPageTitleLargeWithMargin" parent="WizardPageTitleLarge">
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginLeft">16dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginRight">16dp</item>
        <item name="android:paddingLeft">?android:attr/listPreferredItemPaddingLeft</item>
    </style>

    <style name="WizardFormLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">0dp</item>
        <item name="android:textAppearance">?android:textAppearanceSmall</item>
        <item name="android:textColor">@color/text_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingLeft">3dp</item>
        <item name="android:paddingRight">3dp</item>
    </style>

    <style name="WizardFormLabelPaLeRi" parent="WizardFormLabel">
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingRight">12dp</item>
    </style>

    <style name="FormInputStyle">
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>


    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="SmallRSBToolbar" parent="@style/TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:fontFamily">@font/r_sb</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

<!--    <style name="MenuButtonsStyle">-->
<!--        <item name="fab_showAnimation">@anim/jump_from_down</item>-->
<!--        <item name="fab_hideAnimation">@anim/jump_to_down</item>-->
<!--        <item name="fab_shadowColor">#444</item>-->
<!--        <item name="fab_colorNormal">@color/colorAccent</item>-->
<!--        <item name="fab_colorPressed">#F2AB00</item>-->
<!--        <item name="fab_colorRipple">#D99200</item>-->
<!--    </style>-->

    <style name="ImageViewTextTitle" parent="@style/TextAppearance.AppCompat.Menu">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/linear_scrim_mirror</item>
        <item name="android:fontFamily">@font/r_sb</item>
        <item name="android:padding">20dp</item>
        <item name="android:text">@string/example</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="FormInputStylePengtan">
        <item name="android:background">@drawable/rounded_edit</item>
        <item name="android:textSize">14sp</item>
<!--        <item name="ms_background_color">#4B3F3F</item>-->
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">#31FFFFFF</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:layout_marginStart">5dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="TvInputStylePengtan">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#000000</item>
    </style>
</resources>
