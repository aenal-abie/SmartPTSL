<resources>
    <!-- ✅ Base application theme (Material) -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>

        <!-- penting untuk Material -->
        <item name="colorSurface">@android:color/white</item>
        <item name="android:fontFamily">@font/sf_r</item>
    </style>

    <!-- ✅ Dialog theme (FIX ERROR kamu) -->
    <style name="Theme_Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowMinWidthMajor">96%</item>
        <item name="android:windowMinWidthMinor">96%</item>
    </style>

    <!-- ✅ Text Appearance (Material) -->
    <style name="MarkerTitle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:fontFamily">@font/sf_r</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="PolyLineLabelTextStyle" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:fontFamily">@font/sf_r</item>
        <item name="android:textSize">10sp</item>
    </style>

    <!-- Wizard -->
    <style name="WizardPageTitle">
        <item name="android:textSize">23sp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:fontFamily">sans-serif-thin</item>
    </style>

    <style name="WizardPageTitleLarge" parent="WizardPageTitle">
        <item name="android:textSize">36sp</item>
    </style>

    <style name="WizardPageTitleLargeWithMargin" parent="WizardPageTitleLarge">
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <!-- Form -->
    <style name="WizardFormLabel">
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Caption</item>
        <item name="android:textColor">@color/text_light</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="WizardFormLabelPaLeRi" parent="WizardFormLabel">
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="FormInputStyle">
        <item name="android:layout_marginStart">10dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- ✅ Overlay diganti ke Material -->
    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar" />

    <style name="SmallRSBToolbar" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:fontFamily">@font/r_sb</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light" />

    <!-- FAB -->
    <style name="MenuButtonsStyle">
        <item name="fab_showAnimation">@anim/jump_from_down</item>
        <item name="fab_hideAnimation">@anim/jump_to_down</item>
        <item name="fab_shadowColor">#444</item>
        <item name="fab_colorNormal">@color/colorAccent</item>
        <item name="fab_colorPressed">#F2AB00</item>
        <item name="fab_colorRipple">#D99200</item>
    </style>

    <!-- Image title -->
    <style name="ImageViewTextTitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:background">@drawable/linear_scrim_mirror</item>
        <item name="android:fontFamily">@font/r_sb</item>
        <item name="android:padding">20dp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- No Action Bar -->
    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Input -->
    <style name="FormInputStylePengtan">
        <item name="android:background">@drawable/rounded_edit</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">#31FFFFFF</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="TvInputStylePengtan">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#000000</item>
    </style>

</resources>