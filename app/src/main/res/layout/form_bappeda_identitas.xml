<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/tools"
    xmlns:fab="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:ignore="NamespaceTypo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/pekerjaan" />

        <Spinner
            android:id="@+id/bap_pekerjaan"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:entries="@array/jenis_pekerjaan_kkp" />

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/jaminan_sosial_bappeda" />

        <EditText
            android:id="@+id/etbap_jaminan_sosial"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/jaminan_sosial_bappeda" />

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/jumlah_kk" />

        <EditText
            android:id="@+id/etbap_jumlah_kk"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="number"
            android:hint="@string/jumlah_kk" />

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/jumlah_anggota_keluarga" />

        <EditText
            android:id="@+id/etbap_jumlah_anggota_keluarga"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:inputType="number"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/jumlah_anggota_keluarga" />

    </LinearLayout>


</ScrollView>