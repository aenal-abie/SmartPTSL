<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/badan_hukum_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            style="@style/WizardPageTitleLargeWithMargin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:paddingLeft="0dp"
            android:text="@string/fill_when_badan_hukum"
            android:textSize="12sp" />


        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/badan_hukum" />

        <EditText
            android:id="@+id/etBadanHukum"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/badan_hukum" />

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/akta_pendirian" />

        <EditText
            android:id="@+id/etNoAktaPendirian"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/akta_pendirian" />

        <TextView
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/tanggal_akta_pendirian" />

        <EditText
            android:id="@+id/etTanggalAktaPendirian"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:hint="@string/tanggal_akta_pendirian" />

    </LinearLayout>
</ScrollView>