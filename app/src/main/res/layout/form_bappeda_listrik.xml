<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:fab="http://schemas.android.com/apk/res-auto"
            xmlns:app="http://schemas.android.com/tools" android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:ignore="NamespaceTypo">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <TextView
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/sumber_daya_listrik_bappeda"/>
        <Spinner android:layout_width="match_parent"
                 android:layout_height="32dp"
                 android:id="@+id/bap_sumber_daya_listrik"
                 style="@style/FormInputStyle"
                 android:entries="@array/sumber_daya_listrik_bappeda"/>

        <TextView
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/daya_listrik_bappeda"/>
        <Spinner android:layout_width="match_parent"
                 android:layout_height="32dp"
                 android:id="@+id/bap_daya_listrik"
                 style="@style/FormInputStyle"
                 android:entries="@array/daya_listrik_bappeda"/>

    </LinearLayout>


</ScrollView>