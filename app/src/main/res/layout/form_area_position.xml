<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/kelurahan" />

        <EditText
                android:id="@+id/etKelurahan"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/kelurahan"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/dusun"/>

        <EditText
                android:id="@+id/etDusun"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/dusun"/>

        <LinearLayout
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                        style="@style/WizardFormLabel"
                        android:text="@string/rt"/>

                <EditText
                        android:id="@+id/etRt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/rt"
                        android:inputType="number"/>
            </LinearLayout>

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                        style="@style/WizardFormLabel"
                        android:text="@string/rw"/>

                <EditText
                        android:id="@+id/etRw"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/rw"
                        android:inputType="number"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/pbbb_block_no"/>

        <EditText
                android:id="@+id/etPbbbBlockNo"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pbbb_block_no"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/area_status"/>

        <Spinner
                android:id="@+id/sAreaStatus"
                android:entries="@array/area_status_items"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/status_penggunaan"/>

        <Spinner
                android:id="@+id/sStatusPenggunaan"
                android:entries="@array/status_penggunaan_items"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/bukti_penguasaan" />

        <Spinner
            android:id="@+id/sBuktiPenguasaan"
            android:entries="@array/bukti_penguasaan_items"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/shat_no_label"
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/shat_no"
            android:visibility="invisible"
            tools:visibility="visible" />

        <EditText
            android:id="@+id/etShatNo"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/shat_no"
            android:inputType="text"
            android:visibility="invisible"
            tools:visibility="visible" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/WizardFormLabelPaLeRi"
            android:text="@string/luas_tanah" />

        <EditText
            android:id="@+id/etLuasTanah"
            style="@style/FormInputStyle"
            android:layout_width="match_parent"
            android:inputType="numberDecimal"
                android:layout_height="wrap_content"
                android:hint="@string/luas_tanah"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
                style="@style/WizardFormLabelPaLeRi"
                android:text="@string/description"/>

        <EditText
                android:id="@+id/etDescription"
                style="@style/FormInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:inputType="text"/>
    </LinearLayout>
</ScrollView>